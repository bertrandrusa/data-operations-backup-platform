# Queue the sample job hourly. Install only after updating the repository path.
# The scheduler container already handles this in the default Compose deployment.
0 * * * * cd /opt/data-operations-backup-platform && /usr/bin/docker compose exec -T worker /opt/dataops/queue-backup.sh 11111111-1111-4111-8111-111111111111 scheduled >> /var/log/dataops-scheduler.log 2>&1


APP_ENV=development
APP_URL=http://localhost:8080
APP_SESSION_NAME=dataops_session

POSTGRES_DB=dataops
POSTGRES_USER=dataops
POSTGRES_PASSWORD=change-this-database-password
DATABASE_URL=pgsql:host=database;port=5432;dbname=dataops

# Used only to create the first account. Change both values before first start.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe-Now-2026!

# Worker safety boundaries. Jobs must stay beneath these directories.
BACKUP_SOURCE_ROOT=/data/source
BACKUP_TARGET_ROOT=/data/backups
SCHEDULER_INTERVAL_SECONDS=30
WORKER_INTERVAL_SECONDS=5
PROCESSOR_INTERVAL_SECONDS=300
